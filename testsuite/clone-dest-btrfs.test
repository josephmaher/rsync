#!/bin/sh

# Copyright (C) 2024 by Joseph Maher <github@josephmaher.org>
# This program is distributable under the terms of the GNU GPL (see COPYING)
#
# Check that the --clone-dest option makes reflinks as requested

. "$suitedir/rsync.fns"

command -v mkfs.btrfs >/dev/null 2>&1 || test_skipped "Can't find mkfs.btrfs (only available on Linux with btrfs support)"
command -v filefrag >/dev/null 2>&1 || test_skipped "Can't find filefrag (from e2fsprogs)"

# make a btrfs filesystem and mount it. 256M stays clear of the small-image
# thresholds that make mkfs.btrfs switch to mixed mode or fail on some versions.
truncate -s 256M "$scratchdir/btrfs.image"
mkfs.btrfs "$scratchdir/btrfs.image" >/dev/null 2>&1 || test_skipped "mkfs.btrfs failed"
mkdir -p "$scratchdir/mnt/"
mount -o loop "$scratchdir/btrfs.image" "$scratchdir/mnt/" || test_skipped "Can't mount btrfs image file, try running as root"

# Always unmount, even if an assertion below aborts the test, otherwise the
# leaked loop mount can wedge the harness when it cleans up the scratch dir.
# (If rsync.fns ever sets its own EXIT trap, chain to it instead of replacing.)
trap 'cd /; umount "$scratchdir/mnt/" 2>/dev/null' EXIT

# set up some test files and rsync them
mkdir "$scratchdir/mnt/1" "$scratchdir/mnt/2" "$scratchdir/mnt/3"
# Files must exceed btrfs max_inline (default 2048, can be raised toward
# nodesize) or they get inlined and cannot be reflinked. 64K is a safe margin.
dd if=/dev/urandom of="$scratchdir/mnt/1/a" bs=64K count=1 status=none
cp --reflink=never "$scratchdir/mnt/1/a" "$scratchdir/mnt/1/b"
# 3/ is the clone-dest source. 3/a has identical *content* to 1/a; note cp does
# not preserve mtime, so attributes differ - which is fine, --clone-dest clones
# the data regardless of attribute match and then sets attrs from the source.
cp --reflink=never "$scratchdir/mnt/1/a" "$scratchdir/mnt/3/a"

clonedir=$(realpath "$scratchdir/mnt/3")

checkit "$RSYNC -a --clone-dest='$clonedir' '$scratchdir/mnt/1/' '$scratchdir/mnt/2/'" "$scratchdir/mnt/1/" "$scratchdir/mnt/2/"

# Print the physical-offset start of every data extent of a file, in order.
# -s forces a sync so delalloc is flushed and the offsets are stable; -v gives
# the per-extent listing. We match only the numbered extent rows, turn ".."
# into a field separator, and print the physical start column.
get_extents() {
    filefrag -s -v "$1" | awk '/^[[:space:]]*[0-9]+:/ { gsub(/\.\./, " "); print $4 }'
}

# 2/a was built from the clone-dest, so it must share 3/a's physical extents.
ext_2a=$(get_extents "$scratchdir/mnt/2/a")
ext_3a=$(get_extents "$scratchdir/mnt/3/a")
test -n "$ext_2a" || test_fail "no extents found for 2/a (inlined, or filefrag output not parsed?)"
test "$ext_2a" = "$ext_3a" || test_fail "clone-dest file 2/a does not share extents with 3/a"

# 2/b has no counterpart in the clone-dest, so rsync must have copied it
# normally: it must NOT share 3/a's extents, even though the data is identical.
ext_2b=$(get_extents "$scratchdir/mnt/2/b")
test -n "$ext_2b" || test_fail "no extents found for 2/b"
test "$ext_2b" != "$ext_3a" || test_fail "2/b unexpectedly shares extents with the clone-dest"

# unmount happens via the EXIT trap

# The script would have aborted on error, so getting here means we've won.
exit 0
